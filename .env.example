# chaski Environment Variables
# Copy this file to .env and fill in your values
# Note: These are OPTIONAL - you can also configure credentials through the app interface


# ── OpenAI (Required for AI Assistant) ──────────────────────────
# Get your API key from https://platform.openai.com/account/api-keys
OPENAI_API_KEY=your_openai_api_key_here
# OpenAI model to use for the AI assistant (default: gpt-4o-mini)
OPENAI_MODEL=gpt-4o-mini


# ── Gmail / Google Workspace OAuth2 ─────────────────────────────
# See README.md "Gmail / Google Workspace OAuth2 Setup" for step-by-step instructions
GMAIL_CLIENT_ID=your_google_client_id_here
GMAIL_CLIENT_SECRET=your_google_client_secret_here


# ── Microsoft / Outlook OAuth2 ──────────────────────────────────
# See README.md "Outlook / Office 365 OAuth2 Setup" for step-by-step instructions
OUTLOOK_CLIENT_ID=your_microsoft_client_id_here
OUTLOOK_CLIENT_SECRET=your_microsoft_client_secret_here


# ── OAuth2 Callback Server ──────────────────────────────────────
# These configure the local server that captures the OAuth2 redirect.
# The redirect URI registered in your provider console MUST match:
#   http://localhost:{OAUTH_CALLBACK_PORT}{OAUTH_CALLBACK_PATH}
# Or override the full URI with OAUTH_REDIRECT_URI.
OAUTH_CALLBACK_PORT=3000
OAUTH_CALLBACK_PATH=/oauth2/callback
# OAUTH_REDIRECT_URI=http://localhost:3000/oauth2/callback  # Full override (optional)


# ── Debug ───────────────────────────────────────────────────────
# Set to 'true' to enable debug logging to ./debug.log
DEBUG=false

# ── Cache ───────────────────────────────────────────────────────
# Maximum age of cached messages before auto-refresh (in minutes)
CACHE_MAX_AGE=10

# ── Security ────────────────────────────────────────────────────
# Custom encryption salt (improves security of stored credentials)
# If not set, a machine-specific salt is generated automatically
# ENCRYPTION_SALT=your_custom_salt_here


# IMPORTANT SECURITY NOTES:
# 1. Never commit the actual .env file to version control
# 2. Keep your OAuth2 credentials secure and rotate them regularly
# 3. Use app-specific passwords for email providers that support them
# 4. The app stores credentials locally with encryption - no data is sent to external servers
